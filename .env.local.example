# ──────────────────────────────────────────────────────────────────────
# Gonggo.link 환경 변수 설정
# 이 파일을 복사하여 .env.local 로 저장 후 값을 입력하세요
# cp .env.local.example .env.local
# ──────────────────────────────────────────────────────────────────────

# [필수] Anthropic API 키
# https://console.anthropic.com 에서 발급
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE

# [선택] Kakao AdFit 광고 단위 코드 (배포 후 설정)
# https://adfit.kakao.com 에서 발급
NEXT_PUBLIC_ADFIT_SLOT_A=DAN-XXXXXXXXXXXXXXXX   # 상단 배너 (728x90)
NEXT_PUBLIC_ADFIT_SLOT_B=DAN-YYYYYYYYYYYYYYYY   # 분석 중 배너 (320x100)
NEXT_PUBLIC_ADFIT_SLOT_C=DAN-ZZZZZZZZZZZZZZZZ   # 하단 배너 (320x100)
